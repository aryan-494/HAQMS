generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECEPTIONIST
  DOCTOR
}

enum Gender {
  Male
  Female
  Other
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum QueueStatus {
  WAITING
  CALLING
  COMPLETED
  SKIPPED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor?
}

model Doctor {
  id              String   @id @default(cuid())
  name            String
  specialization  String
  department      String
  experience      Int      @default(0)
  consultationFee Float    @default(0)
  availableFrom   String   @default("09:00")
  availableTo     String   @default("17:00")

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  queueTokens  QueueToken[]

  @@index([specialization])
  @@index([department])
}

model Patient {
  id             String   @id @default(cuid())
  name           String
  email          String?
  phoneNumber    String
  age            Int
  gender         String
  medicalHistory String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  queueTokens  QueueToken[]

  @@index([name])
  @@index([phoneNumber])
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  appointmentDate DateTime
  reason          String?
  status          AppointmentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([patientId])
  @@index([status])
  @@index([appointmentDate])

  // Optional improvement:
  // @@unique([doctorId, appointmentDate])
}

model QueueToken {
  id            String      @id @default(cuid())
  tokenNumber   Int
  patientId     String
  doctorId      String
  appointmentId String?
  status        QueueStatus @default(WAITING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([status])
  @@index([createdAt])

  @@unique([doctorId, tokenNumber])
}